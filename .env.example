# --- Servidor ---
PORT=3000
NODE_ENV=development
# Segredo para assinar o token de sessão pós-OTP. Trocar em produção.
JWT_SECRET=troque-este-segredo-em-producao

# --- Banco (MVP: SQLite local; escala: Postgres) ---
DB_URL=./data/icontabil.sqlite

# --- API de CNPJ (preview cadastral) ---
# Ex.: BrasilAPI (grátis) ou CNPJá/Sintegra (pagas). Ver cnpjService.js.
API_CNPJ_BASE=https://brasilapi.com.br/api/cnpj/v1

# --- Calculadora oficial IBS/CBS (REST, seção 3 do CLAUDE.md) ---
# Base da API (a rota /calculadora/regime-geral é anexada pelo código).
#   Offline (jar local):  http://localhost:8080/api
#   Piloto online:        https://piloto-cbs.tributos.gov.br/servico/calculadora-consumo/api
# Vazio = modo mock (alíquota de referência ~26,5%). Ver calculadora/README.md.
CALCULADORA_URL=

# --- OTP por e-mail ---
# SMTP_PROVIDER: 'brevo' ou 'resend'. Vazio = modo dev (código sai no log, não envia e-mail).
#   Brevo:  https://app.brevo.com → SMTP & API → API Keys
#   Resend: https://resend.com/api-keys (exige domínio verificado em OTP_FROM)
# Em produção, preencher os dois para o usuário receber o código de verdade.
SMTP_PROVIDER=
SMTP_API_KEY=
OTP_FROM=contato@icontabil.com.br
OTP_TTL_MIN=10

# --- Lead-gen: webhook do N8N (seção 8) ---
N8N_WEBHOOK_URL=

# --- Cota do free tier (seção 6) ---
FREE_TIER_LIMITE=3
